{
    "name": "devkussema/acapadev-sdk",
    "description": "Acapadev Official SDK for Laravel applications (Webhooks, SSO, Utilities)",
    "type": "library",
    "license": "MIT",
    "authors": [
        {
            "name": "Augusto Kussema",
            "email": "dev.kussema@acapadev.com"
        }
    ],
    "require": {
        "php": "^8.2",
        "illuminate/support": "^11.0 || ^12.0 || ^13.0",
        "illuminate/http": "^11.0 || ^12.0 || ^13.0",
        "illuminate/routing": "^11.0 || ^12.0 || ^13.0",
        "laravel/socialite": "^5.0"
    },
    "autoload": {
        "psr-4": {
            "Acapadev\\Sdk\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Acapadev\\Sdk\\Tests\\": "tests/"
        }
    },
    "extra": {
        "laravel": {
            "providers": [
                "Acapadev\\Sdk\\AcapadevServiceProvider"
            ]
        }
    },
    "minimum-stability": "dev",
    "prefer-stable": true,
    "require-dev": {
        "orchestra/testbench": "^9.0",
        "phpunit/phpunit": "^11.0",
        "larastan/larastan": "^2.9"
    }
}
